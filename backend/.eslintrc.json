{
  "env": {
    "node": true,
    "es2021": true,

  },
  "extends": [
    "eslint:recommended"
  ],

  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "globals": {
    "GMAIL_USER": "readonly",
    "otherUser": "readonly",
    "otherToken": "readonly"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off"
  }
}
